#. Plugin Name of the plugin
#: priceblueprint-for-woocommerce.php
msgid "PriceBlueprint for WooCommerce"
msgstr ""

#. Description of the plugin
#: priceblueprint-for-woocommerce.php
msgid ""
"Configurable product pricing via reusable Price Blueprints. Assign one "
"template to many products; prices are always calculated from live CPT rules."
msgstr ""
"Настраиваемое ценообразование товаров с помощью многоразовых "
"PriceBlueprints. Назначайте один шаблон многим товарам; цены всегда "
"рассчитываются по актуальным правилам CPT."

#. Author of the plugin
#: priceblueprint-for-woocommerce.php
msgid "Edgar Khachaturov"
msgstr ""

#: src/Admin/HelpTab.php:28
msgid "Overview"
msgstr "Обзор"

#: src/Admin/HelpTab.php:34
msgid "Adding Rules"
msgstr "Добавление правил"

#: src/Admin/HelpTab.php:40
msgid "How the Price is Calculated"
msgstr "Как рассчитывается цена"

#: src/Admin/HelpTab.php:46
msgid "Assigning to a Product"
